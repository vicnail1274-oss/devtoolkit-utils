{
  "name": "devtoolkit-utils",
  "version": "1.0.0",
  "description": "Lightweight developer utility functions — JSON formatting, Base64 encoding, URL encoding, hash generation, UUID, cron parsing, and more. Zero dependencies.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "node --test tests/",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "developer-tools",
    "json-formatter",
    "base64",
    "url-encode",
    "uuid",
    "hash",
    "cron",
    "css-minify",
    "utilities",
    "devtools"
  ],
  "author": "DevToolkit <hello@devtoolkit.cc>",
  "license": "MIT",
  "homepage": "https://devtoolkit-db7.pages.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/vicnail1274-oss/devtoolkit-utils"
  },
  "bugs": {
    "url": "https://github.com/vicnail1274-oss/devtoolkit-utils/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
